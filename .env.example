APP_NAME="SST Manager"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=http://localhost:8000
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR

# ─── BANCO DE DADOS ───────────────────────────────────────────────
# Use DB_HOST=127.0.0.1 para PostgreSQL local (instalado na máquina)
# Use os dados do Supabase/nuvem se usar banco remoto
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=sst_db
DB_USERNAME=postgres
DB_PASSWORD=SUA_SENHA_AQUI

# ─── CACHE / SESSION ──────────────────────────────────────────────
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

# ─── LOGS ─────────────────────────────────────────────────────────
LOG_CHANNEL=daily
LOG_LEVEL=debug

# ─── EMAIL (opcional para desenvolvimento local) ──────────────────
MAIL_MAILER=log
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@seudominio.com.br
MAIL_FROM_NAME="SST Manager"

# ─── FILESYSTEM ───────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ─── SEGURANÇA ────────────────────────────────────────────────────
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOGIN_THROTTLE_MINUTES=15

# ─── RATE LIMITING ────────────────────────────────────────────────
RATE_LIMIT_API=60
RATE_LIMIT_LOGIN=5

# ─── SISTEMA SST ──────────────────────────────────────────────────
SST_SYSTEM_NAME="SST Manager"
SST_SYSTEM_LOGO=
SST_VERSION=2.0.0
SST_MULTIEMPRESA=true

# ══════════════════════════════════════════════════════════════════
# PRODUÇÃO: altere os valores abaixo antes de fazer deploy
#   APP_ENV=production
#   APP_DEBUG=false
#   APP_URL=https://seudominio.com.br
#   SESSION_ENCRYPT=true
#   BCRYPT_ROUNDS=12
#   LOG_LEVEL=warning
#   MAIL_MAILER=smtp  (configurar credenciais reais)
# Veja DEPLOY_VPS.md para guia completo de produção.
# ══════════════════════════════════════════════════════════════════
